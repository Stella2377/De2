@using De2.Models.Entities
@inject De2.Services.IPrescriptionService PrescriptionService
@model De2.Models.Entities.Prescription

@{
    ViewData["Title"] = "Chi tiết đơn thuốc";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header @(Model is SpecialPrescription ? "bg-danger" : "bg-primary") text-white">
            <h3 class="mb-0">Thông Tin Đơn Thuốc: @Model.PrescriptionId</h3>
        </div>
        <div class="card-body">
            <div class="row mb-4">
                <div class="col-sm-4 fw-bold">Tên bệnh nhân:</div>
                <div class="col-sm-8">@Model.PatientName</div>
            </div>
            
            <div class="row mb-4">
                <div class="col-sm-4 fw-bold">Ngày tạo:</div>
                <div class="col-sm-8">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            <hr />

            @* Logic hiển thị theo từng loại đơn thuốc bằng Pattern Matching *@
            @if (Model is StandardPrescription standard)
            {
                <div class="alert alert-info">
                    <h5>Loại đơn: Đơn thuốc thường</h5>
                    <p>Đơn giá: @standard.UnitPrice.ToString("N0") VNĐ</p>
                    <p>Số lượng: @standard.Quantity</p>
                </div>
            }
            else if (Model is SpecialPrescription special)
            {
                <div class="alert alert-warning border-danger">
                    <h5>Loại đơn: Đơn thuốc đặc biệt</h5>
                    <p>Đơn giá: @special.UnitPrice.ToString("N0") VNĐ</p>
                    <p>Số lượng: @special.Quantity</p>
                    <p>Phí lưu kho: @special.StorageFee.ToString("N0") VNĐ</p>
                    <p class="text-danger fw-bold">Mã GP bác sĩ: @(special.DoctorLicense ?? "N/A")</p>
                </div>
            }

            <div class="row mt-4 p-3 bg-light rounded">
                <div class="col-sm-4 h4">Tổng cộng:</div>
                <div class="col-sm-8 h4 text-success">
                    @PrescriptionService.CalculateTotal(Model).ToString("N0") VNĐ
                </div>
            </div>
        </div>
        <div class="card-footer bg-white">
            <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
            <button class="btn btn-primary" onclick="window.print()">In đơn thuốc</button>
        </div>
    </div>
</div>